{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Home","text":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u77e5\u8bc6\u5e93 \u5f00\u59cb\u63a2\u7d22 \u2192 \u5173\u4e8e\u672c\u7ad9"},{"location":"PLC/PLC%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/","title":"PLC","text":"<p>S7-200 SMART-PLC</p>"},{"location":"about/%E6%9B%B4%E6%96%B0%E6%97%A5%E5%BF%97/","title":"\u66f4\u65b0\u65e5\u5fd7","text":"<ul> <li>3.9\u66f4\u65b0\uff1a</li> </ul> <p>\u5b8c\u6210\u57fa\u672c\u9875\u9762\u642d\u5efa</p> <p>\u5c1d\u8bd5\u4e3b\u9875\u56fe\u7247\uff0c\u8fd8\u6ca1\u641e\u660e\u767d</p> <p>\u4e8e\u662f\u5728mkdocs.yml\u4e2d\u6ce8\u91ca\u6389\u4e86 custom_dir: overrides </p> <ul> <li>3.10\u66f4\u65b0\uff1a</li> </ul> <p>\u6dfb\u52a0\u4e86Home\u9875\u56fe\u7247\uff0c\u4e2d\u95f4\u66f4\u8fed\u4e86\u5404\u79cd\u7f51\u9875\u7684\u5f62\u5f0f\uff0c\u6700\u540e\u6539\u6210\u4e86\u4e3b\u9875\u5927\u56fe\u7684\u5f62\u5f0f\uff08\u5b8c\u5168\u53c2\u8003\u9879\u76eefoorgange \uff09</p> <p>\u6dfb\u52a0\u4e86github\u4ed3\u5e93\u94fe\u63a5</p>"},{"location":"%E6%80%9D%E8%80%83/%E4%B9%96%E5%AD%A9%E5%AD%90%E8%AF%AF%E5%8C%BA/","title":"\u201c\u4e56\u5b69\u5b50\u201d\u8bef\u533a","text":"<p>\u6709\u6b32\u671b\u5176\u5b9e\u662f\u6b63\u5e38\u73b0\u8c61</p> <p>\u5927\u5bb6\u90fd\u6709\uff0c\u53f8\u7a7a\u89c1\u60ef\uff0c\u6b63\u5e38\u7684\u751f\u7406\u73b0\u8c61\uff0c\u6211\u5374\u611f\u5230\u7f9e\u803b\u4e0d\u597d\u610f\u601d</p> <p>\u5c31\u548c\u6211\u4e0d\u597d\u610f\u601d\u5728\u5927\u5ead\u5e7f\u4f17\u4e4b\u4e0b\u73a9\u6e38\u620f\u4e00\u6837</p> <p>\u5c31\u548c\u6211\u4e0d\u597d\u610f\u601d\u53bb\u8c08\u604b\u7231\u8ba9\u522b\u4eba\u77e5\u9053\u4e00\u6837</p> <p>\u5c31\u548c\u6211\u4e0d\u597d\u610f\u601d\u53d1\u670b\u53cb\u5708\u4e00\u6837</p> <p>\u53ef\u80fd\u90fd\u662f\u56e0\u4e3a\u6211\u4ece\u5c0f\u5c31\u88ab\u6559\u80b2\u8981\u5f53\u4e56\u5b69\u5b50</p> <p>\u4ece\u5c0f\u7684\u4e56\u5b69\u5b50\u89c4\u8bad\u8ba9\u6211\u517b\u6210\u4e86\u601d\u7ef4\u60ef\u6027\uff0c\u517b\u6210\u4e86\u9519\u8bef\u7684\u4e16\u754c\u89c2\u4eba\u751f\u89c2\u4ef7\u503c\u89c2</p> <p>\u624d\u8ba9\u6211\u5728\u9ad8\u4e2d\uff0c\u5927\u5b66\u5982\u6b64\u675f\u624b\u675f\u811a</p> <p>\u771f\u7684\u8be5\u6162\u6162\u6539\u53d8\u8fd9\u4e00\u70b9\u4e86</p>"},{"location":"%E6%80%9D%E8%80%83/%E5%85%B3%E4%BA%8E%E8%8A%B1%E9%92%B1/","title":"\u5173\u4e8e\u82b1\u94b1","text":"<p>\u4e00\u4e2a\u4eba\u7684\u8ba4\u77e5\u5c31\u51b3\u5b9a\u4e86\u4ed6\u8fd9\u4e00\u751f</p> <p>\u4e00\u4e2a\u4eba\u6c38\u8fdc\u4e5f\u8d5a\u4e0d\u5230\u8ba4\u77e5\u4e4b\u5916\u7684\u94b1</p> <p>\u51fa\u8eab\uff0c\u6559\u80b2\uff0c\u786e\u5b9e\u5c31\u53ef\u4ee5\u51b3\u5b9a\u4e00\u4e2a\u4eba\u7684\u4e00\u751f</p> <p>\u522b\u4eba\u7684\u7236\u6bcd\u8d5a\u94b1\u5e26\u5b69\u5b50\u51fa\u53bb\u65c5\u6e38\uff0c\u51fa\u53bb\u89c1\u4e16\u9762\uff0c\u8fd9\u6837\u7684\u5b69\u5b50\uff0c\u4ee5\u540e\u53ef\u4ee5\u8d5a\u66f4\u591a\u7684\u94b1</p> <p>\u800c\u6211\u7684\u7236\u6bcd\u53ea\u77e5\u9053\u628a\u8d5a\u7684\u672c\u5c31\u4e0d\u591a\u7684\u94b1\u7701\u4e0b\u6765\uff0c\u81ea\u5df1\u65e0\u6bd4\u8282\u4fed\uff0c\u820d\u4e0d\u5f97\u82b1\uff0c\u66f4\u522b\u63d0\u5e26\u5b69\u5b50\u51fa\u53bb\u957f\u89c1\u8bc6\uff0c\u7f8e\u5176\u540d\u66f0\u201c\u4e3a\u4f60\u7701\u94b1\uff0c\u7701\u4e0b\u6765\u7684\u90fd\u662f\u4f60\u7684\u201d\uff0c\u5b9e\u9645\u4e0a\u5b69\u5b50\u6700\u4e3a\u7f3a\u4e4f\u7684\u4e0d\u662f\u8fd9\u4e00\u70b9\u94b1\uff0c\u800c\u662f\u826f\u597d\u7684\u8ba4\u77e5\u548c\u6559\u80b2\uff0c\u6700\u7ec8\u5b69\u5b50\u56e0\u4e3a\u4ece\u5c0f\u7684\u81ea\u5351\u3001\u773c\u754c\u548c\u540c\u9f84\u4eba\u76f8\u6bd4\u5dee\u4e4b\u751a\u8fdc\uff0c\u4e5f\u50cf\u7236\u6bcd\u4e00\u6837\u6323\u4e0d\u5230\u94b1\uff0c\u4e5f\u50cf\u7236\u6bcd\u4e00\u6837\u788c\u788c\u65e0\u4e3a\u4e00\u751f\uff0c\u800c\u4e14\u4e5f\u53d7\u5230\u4e86\u7236\u6bcd\u7684\u5f71\u54cd\uff0c\u7ee7\u7eed\u5f71\u54cd\u4e0b\u4e00\u4ee3\uff0c\u8fd9\u6837\u4e00\u4e2a\u5bb6\u65cf\u90fd\u6c38\u8fdc\u4e0d\u80fd\u7ffb\u8eab</p> <p>\u5bcc\u8005\u6108\u5bcc\uff0c\u7a77\u8005\u6108\u7a77</p> <p>\u4e00\u4e2a\u4e0d\u4f1a\u82b1\u94b1\u7684\u4eba\u6c38\u8fdc\u8d5a\u4e0d\u5230\u94b1</p> <p>\u771f\u7684\u73a9\u6e38\u620f\u5c31\u5f97\u5fae\u6c2a</p> <p>\u5982\u679c\u4f60\u73a9\u6e38\u620f\u662f\u4e3a\u4e86\u5feb\u4e50\u7684\u8bdd</p> <p>\u4f60\u8f9b\u8f9b\u82e6\u82e6\u809d\u4e00\u5e74\uff0c\u53ef\u80fd\u8fd8\u4e0d\u5982\u6211\u8fd9\u4e00\u4e24\u767e\u5757\u94b1</p> <p>\u81f3\u5c11\u6211\u8fd9\u4e00\u4e24\u767e\u5757\u94b1\u662f\u5b9e\u5b9e\u5728\u5728\u7684\u5feb\u4e50\u4e86\u7684</p> <p>\u6211\u77e5\u9053\u6211\u5bd2\u5047\u653e\u5b8c\u4e00\u5b9a\u4f1a\u9000\u6e38</p> <p>\u4f46\u81f3\u5c11\u6211\u8fd9\u4e2a\u5bd2\u5047\u5b9e\u5b9e\u5728\u5728\u7684\u5feb\u4e50\u4e86</p> <p>\u800c\u4e14\u4ee3\u4ef7\u4e5f\u5c31\u4e00\u767e\u5757\uff0c\u4e0d\u4f1a\u6709\u4efb\u4f55\u7c98\u6027\uff0c\u9000\u6e38\u5c31\u9000\u6e38\u4e86</p> <p>\u5982\u679c\u4f60\u820d\u4e0d\u5f97\u5145\u4e00\u5206\uff0c\u575a\u6301\u96f6\u6c2a</p> <p>\u8f9b\u8f9b\u82e6\u82e6\u809d\u4e00\u5e74</p> <p>\u4e0d\u4ec5\u5feb\u4e50\u4e0d\u4e86</p> <p>\u800c\u4e14\u5230\u4e86\u8be5\u52aa\u529b\u5de5\u4f5c\u65f6\u8fd8\u820d\u4e0d\u5f97</p> <p>\u6bd5\u7adf\u82b1\u4e86\u8fd9\u4e48\u591a\u65f6\u95f4</p>"},{"location":"%E6%9C%BA%E6%A2%B0/%E6%9C%AA%E6%9D%A5%E6%96%B9%E5%90%91/","title":"\u672a\u6765\u65b9\u5411","text":"<p>\u672a\u6765\u80fd\u6e90\u4e0e\u7a7a\u5929\u88c5\u5907 \u5de5\u4e1a\u8f6f\u4ef6\u4e0eAI for Engineering \u672a\u6765\u5236\u9020\uff1a4D\u6253\u5370\u4e0e\u667a\u80fd\u6750\u6599 \u6781\u7aef\u4e0e\u5fae\u7eb3\u5236\u9020 \u667a\u80fd\u6750\u6599\u4e0e\u8d85\u6750\u6599\u7ed3\u6784 \u9ad8\u7aef\u88c5\u5907\u7684\u667a\u80fd\u5316\u201c\u517b\u751f\u201d\uff08\u6545\u969c\u8bca\u65ad\uff09</p> <p>\u4eba\u5f62\u4eff\u751f\u673a\u5668\u4eba \u53ef\u7a7f\u6234\u673a\u5668\u4eba\uff08\u5916\u9aa8\u9abc\uff09 \u533b\u7597\u673a\u5668\u4eba \u5de5\u4e1a\u673a\u5668\u4eba/\u667a\u80fd\u5236\u9020 \u6545\u969c\u8bca\u65ad\uff08\u5065\u5eb7\u7ba1\u7406/\u8fd0\u7ef4\uff09 \u7ed3\u6784\u8bbe\u8ba1</p>"},{"location":"%E6%9D%82%E4%B8%83%E6%9D%82%E5%85%AB/mkdocs%E7%AC%94%E8%AE%B0/","title":"\u6742\u4e03\u6742\u516b","text":"<p>\u90e8\u7f72\u5230Github\uff1a</p> <pre><code>mkdocs gh-deploy\n</code></pre> <p>mkdocs\uff1a</p> <ul> <li>\u65e0nav\uff1a \u6309\u7167\u6709\u6587\u4ef6\u7684\u6587\u4ef6\u5939\u540d\u79f0\u5f62\u6210\u5bfc\u822a \u6587\u4ef6\u5939\u4e2d\u5b50\u6587\u4ef6\u7684\u6807\u9898\u6309\u7167\u6e90\u6587\u4ef6\u7684\u6807\u9898\u800c\u5b9a \u81ea\u52a8\u751f\u6210home\u680f</li> <li>\u6709nav: \u6574\u4e2a\u76ee\u5f55\u7ed3\u6784\u91cd\u65b0\u7ec4\u7ec7 \u6e90\u6587\u4ef6\u5939\u7684\u6587\u4ef6\u5939\u540d\u3001\u6587\u4ef6\u540d\u90fd\u4e0d\u518d\u8d77\u4f5c\u7528 \u7f51\u9875\u4e2d\u7684\u6807\u9898\u5b8c\u5168\u4f9d\u7167nav\u4e2d\u7684\u540d\u79f0</li> </ul> <p>\u6700\u597d\uff1a\u76ee\u5f55\u7ed3\u6784\u6309\u7167\u89c4\u8303\uff1b\u540c\u65f6\u4f7f\u7528nav\u89c4\u8303</p>"}]}