{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Home","text":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u77e5\u8bc6\u5e93 \u5f00\u59cb\u63a2\u7d22 \u2192 \u5173\u4e8e\u672c\u7ad9"},{"location":"PLC/PLC%E5%AD%A6%E4%B9%A0%E7%AC%94%E8%AE%B0/","title":"PLC","text":"<p>S7-200 SMART-PLC</p>"},{"location":"%E6%9C%BA%E6%A2%B0/%E6%9C%AA%E6%9D%A5%E6%96%B9%E5%90%91/","title":"\u672a\u6765\u65b9\u5411","text":"<p>\u672a\u6765\u80fd\u6e90\u4e0e\u7a7a\u5929\u88c5\u5907 \u5de5\u4e1a\u8f6f\u4ef6\u4e0eAI for Engineering \u672a\u6765\u5236\u9020\uff1a4D\u6253\u5370\u4e0e\u667a\u80fd\u6750\u6599 \u6781\u7aef\u4e0e\u5fae\u7eb3\u5236\u9020 \u667a\u80fd\u6750\u6599\u4e0e\u8d85\u6750\u6599\u7ed3\u6784 \u9ad8\u7aef\u88c5\u5907\u7684\u667a\u80fd\u5316\u201c\u517b\u751f\u201d\uff08\u6545\u969c\u8bca\u65ad\uff09</p> <p>\u4eba\u5f62\u4eff\u751f\u673a\u5668\u4eba \u53ef\u7a7f\u6234\u673a\u5668\u4eba\uff08\u5916\u9aa8\u9abc\uff09 \u533b\u7597\u673a\u5668\u4eba \u5de5\u4e1a\u673a\u5668\u4eba/\u667a\u80fd\u5236\u9020 \u6545\u969c\u8bca\u65ad\uff08\u5065\u5eb7\u7ba1\u7406/\u8fd0\u7ef4\uff09 \u7ed3\u6784\u8bbe\u8ba1</p>"},{"location":"%E6%9D%82%E4%B8%83%E6%9D%82%E5%85%AB/mkdocs%E7%AC%94%E8%AE%B0/","title":"\u6742\u4e03\u6742\u516b","text":"<p>\u90e8\u7f72\u5230Github\uff1a</p> <pre><code>mkdocs gh-deploy\n</code></pre> <p>mkdocs\uff1a</p> <ul> <li>\u65e0nav\uff1a \u6309\u7167\u6709\u6587\u4ef6\u7684\u6587\u4ef6\u5939\u540d\u79f0\u5f62\u6210\u5bfc\u822a \u6587\u4ef6\u5939\u4e2d\u5b50\u6587\u4ef6\u7684\u6807\u9898\u6309\u7167\u6e90\u6587\u4ef6\u7684\u6807\u9898\u800c\u5b9a \u81ea\u52a8\u751f\u6210home\u680f</li> <li>\u6709nav: \u6574\u4e2a\u76ee\u5f55\u7ed3\u6784\u91cd\u65b0\u7ec4\u7ec7 \u6e90\u6587\u4ef6\u5939\u7684\u6587\u4ef6\u5939\u540d\u3001\u6587\u4ef6\u540d\u90fd\u4e0d\u518d\u8d77\u4f5c\u7528 \u7f51\u9875\u4e2d\u7684\u6807\u9898\u5b8c\u5168\u4f9d\u7167nav\u4e2d\u7684\u540d\u79f0</li> </ul> <p>\u6700\u597d\uff1a\u76ee\u5f55\u7ed3\u6784\u6309\u7167\u89c4\u8303\uff1b\u540c\u65f6\u4f7f\u7528nav\u89c4\u8303</p>"}]}